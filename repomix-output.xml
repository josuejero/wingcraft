<file path="frontend/src/App.css">
.console-shell {
  min-height: 100vh;
  padding: 2rem clamp(1rem, 3vw, 2.5rem) 4rem;
  background: radial-gradient(circle at top, rgba(59, 130, 246, 0.3), transparent 45%), #030711;
  color: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  font-family: 'Inter', system-ui, sans-serif;
}

.hero {
  max-width: 860px;
  margin: 0 auto;
}

.hero h1 {
  margin: 0.25rem 0;
  font-size: clamp(2.25rem, 4vw, 3rem);
}

.hero-copy {
  margin: 0;
  color: #cbd5f5;
  font-size: 1.05rem;
}

.eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.3em;
  font-size: 0.72rem;
  color: #94a3b8;
  margin: 0;
}

.panel {
  background: rgba(15, 23, 42, 0.75);
  border: 1px solid #1f2937;
  border-radius: 1.25rem;
  padding: 1.5rem;
  box-shadow: 0 25px 45px rgba(2, 6, 23, 0.6);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.panel-subtitle {
  margin: 0.35rem 0 0;
  color: #cbd5f5;
}

.panel-hint {
  font-size: 0.9rem;
  color: #94a3b8;
}

.incident-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 0.85rem;
}

.incident-card {
  background: #0b1120;
  border: 1px solid transparent;
  border-radius: 0.9rem;
  padding: 1rem;
  text-align: left;
  color: inherit;
  cursor: pointer;
  transition: border 0.2s ease, transform 0.2s ease;
}

.incident-card.active {
  border-color: #38bdf8;
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(56, 189, 248, 0.35);
}

.incident-card:hover {
  border-color: #94a3b8;
}

.incident-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.5rem;
}

.incident-id {
  font-size: 0.85rem;
  color: #94a3b8;
}

.incident-badge {
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  padding: 0.25rem 0.5rem;
  border-radius: 999px;
  background: rgba(59, 130, 246, 0.2);
}

.incident-label {
  margin: 0.5rem 0 0;
  font-weight: 600;
}

.incident-meta {
  margin: 0.15rem 0 0;
  font-size: 0.85rem;
  color: #cbd5f5;
}

.upload-panel textarea {
  width: 100%;
  min-height: 190px;
  background: #020617;
  border: 1px solid #1f2937;
  border-radius: 0.9rem;
  padding: 1rem;
  font-family: 'JetBrains Mono', 'SFMono-Regular', monospace;
  color: #f8fafc;
  resize: vertical;
}

.actions {
  margin-top: 0.9rem;
  display: flex;
  align-items: center;
  gap: 0.9rem;
}

.upload-actions {
  display: flex;
  gap: 0.5rem;
}

button {
  border: none;
  border-radius: 0.65rem;
  padding: 0.65rem 1.25rem;
  font-weight: 600;
  cursor: pointer;
  background: #2563eb;
  color: #f8fafc;
  transition: background 0.2s ease;
}

button:hover:not(:disabled) {
  background: #1d4ed8;
}

button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

button.ghost {
  background: transparent;
  border: 1px solid #94a3b8;
  color: #e2e8f0;
}

.upload-hint {
  margin: 0.75rem 0 0;
  font-size: 0.85rem;
  color: #94a3b8;
}

.error {
  color: #f87171;
  font-size: 0.9rem;
}

.diagnosis-grid,
.action-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}

.diagnosis-grid article,
.action-grid article,
.evidence-section {
  border: 1px solid #1f2937;
  border-radius: 1rem;
  padding: 1rem;
  background: rgba(15, 23, 42, 0.7);
}

.diagnosis-grid h3,
.action-grid h3 {
  margin: 0 0 0.35rem;
}

.muted {
  color: #94a3b8;
  font-size: 0.9rem;
  margin: 0;
}

.evidence-section ul,
.action-grid ul,
.evidence-section ul li,
.action-grid li {
  margin: 0;
  padding: 0;
  list-style: none;
}

.evidence-section ul {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.evidence-section li,
.action-grid li {
  background: rgba(30, 41, 59, 0.6);
  border-radius: 0.6rem;
  padding: 0.45rem 0.6rem;
  font-family: 'JetBrains Mono', 'SFMono-Regular', monospace;
  font-size: 0.85rem;
}

.confidence-track {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  background: #1e293b;
  margin: 0.5rem 0;
}

.confidence-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #22d3ee, #38bdf8);
}

.escalation-pill {
  text-align: center;
  border-radius: 1.1rem;
  min-height: 150px;
}

.escalation-pill.escalate {
  border: 1px solid rgba(248, 113, 113, 0.4);
}

.escalation-pill.resolved {
  border: 1px solid rgba(16, 185, 129, 0.4);
}

.customer-panel .reply-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.reply-block {
  background: #020617;
  border: 1px solid #1f2937;
  border-radius: 0.9rem;
  padding: 1rem;
  white-space: pre-wrap;
  margin: 0;
  font-family: 'Inter', system-ui, sans-serif;
}

.copy-status {
  color: #38bdf8;
  font-size: 0.85rem;
}

.checklist-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 0.85rem;
}

.checklist-step {
  background: rgba(15, 23, 42, 0.8);
  border: 1px solid rgba(148, 163, 184, 0.3);
  border-radius: 0.9rem;
  padding: 0.9rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.checklist-step:hover {
  border-color: rgba(56, 189, 248, 0.7);
  box-shadow: 0 12px 24px rgba(2, 6, 23, 0.35);
}

.checklist-step-heading {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.checkbox {
  width: 18px;
  height: 18px;
  border-radius: 0.3rem;
  border: 1px solid #94a3b8;
  background: rgba(56, 189, 248, 0.15);
}

.step-number {
  margin: 0;
  font-size: 0.75rem;
  color: #94a3b8;
  letter-spacing: 0.15em;
}

.step-title {
  margin: 0;
  font-size: 1rem;
  font-weight: 600;
  color: #e2e8f0;
}

.step-detail,
.step-note {
  margin: 0;
  font-size: 0.88rem;
  color: #cbd5f5;
}

.step-note {
  color: #94a3b8;
  font-style: italic;
}

.about-panel p {
  margin: 0.35rem 0;
  color: #cbd5f5;
}

@media (max-width: 720px) {
  .panel-header {
    align-items: flex-start;
  }

  .actions,
  .upload-actions,
  .customer-panel .reply-actions {
    flex-direction: column;
    align-items: stretch;
  }
}
</file>

