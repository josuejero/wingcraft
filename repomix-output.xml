<file path="ops-lab/scripts/collect-evidence.sh">
#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
mkdir -p logs

docker compose logs --no-color --tail 120 paper > "logs/evidence-${timestamp}.log"
docker compose ps paper > "logs/ps-${timestamp}.txt"
docker inspect wingcraft-paper > "logs/inspect-${timestamp}.json"
</file>

<file path="ops-lab/scripts/stop-server.sh">
#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

docker compose down
</file>

<file path="ops-lab/scripts/tail-logs.sh">
#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

docker compose logs --no-color --tail 60 paper
</file>

<file path="ops-lab/docker-compose.yml">
version: '3.9'

services:
  paper:
    image: "itzg/paper:${PAPER_IMAGE_TAG:-latest}"
    container_name: wingcraft-paper
    env_file:
      - env/common.env
    ports:
      - '${MINECRAFT_PORT:-25565}:25565'
    environment:
      EULA: 'TRUE'
      MAX_MEMORY: '${MAX_MEMORY:-2G}'
    volumes:
      - paper_configs:/data
      - paper_world:/data/world
      - paper_logs:/data/logs
    healthcheck:
      test: ["CMD-SHELL","bash -c 'cat < /dev/tcp/127.0.0.1/${MINECRAFT_PORT:-25565} >/dev/null 2>&1'"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
    tty: true
    stdin_open: true

  fault-injector:
    image: alpine:3.18
    profiles: [fault-injector]
    working_dir: /work
    command: ["sleep", "infinity"]
    volumes:
      - ./scripts/fault-injector:/work
      - paper_logs:/data/logs
      - paper_configs:/data
    depends_on:
      - paper

volumes:
  paper_world:
    name: wingcraft_paper_world
  paper_logs:
    name: wingcraft_paper_logs
  paper_configs:
    name: wingcraft_paper_configs
</file>

